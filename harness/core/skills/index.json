{
  "schemaVersion": 1,
  "skills": {
    "superpowers": {
      "source": "https://github.com/obra/superpowers",
      "baselinePath": "harness/upstream/superpowers/skills",
      "layout": "collection",
      "projection": {
        "default": "materialize",
        "copilot": "materialize",
        "cursor": "materialize",
        "codex": "materialize",
        "claude-code": "materialize"
      },
      "childPatches": {
        "writing-plans": {
          "type": "superpowers-writing-plans",
          "marker": "Harness Superpowers writing-plans location patch"
        }
      },
      "hooks": {
        "cursor": {
          "source": "harness/upstream/superpowers/hooks",
          "config": "hooks-cursor.json",
          "events": ["sessionStart"]
        },
        "claude-code": {
          "source": "harness/upstream/superpowers/hooks",
          "config": "hooks.json",
          "events": ["SessionStart"]
        },
        "codex": {
          "source": "harness/core/hooks/superpowers",
          "config": "codex-hooks.json",
          "scriptRoot": "scripts",
          "scripts": ["session-start", "run-hook.cmd"],
          "events": ["SessionStart"]
        }
      }
    },
