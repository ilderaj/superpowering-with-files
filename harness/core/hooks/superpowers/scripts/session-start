#!/usr/bin/env bash
set -euo pipefail

root="${HARNESS_PROJECT_ROOT:-$(pwd)}"

json_escape() {
  node -e 'let input = ""; process.stdin.setEncoding("utf8"); process.stdin.on("data", chunk => { input += chunk; }); process.stdin.on("end", () => { process.stdout.write(JSON.stringify(input)); });'
}

context="$(cat <<'EOF'
<EXTREMELY_IMPORTANT>
You have superpowers.

Before acting, check the projected skill relevant to the task.
Keep simple tasks lightweight.
For complex tasks, use the right process skill and sync durable state back to planning/active/<task-id>/.
</EXTREMELY_IMPORTANT>
EOF
)"
escaped="$(printf '%s' "$context" | json_escape)"

printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":%s}}\n' "$escaped"
