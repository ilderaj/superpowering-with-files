{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "sh -c '[ -f .github/hooks/session-checkpoint.sh ] && bash .github/hooks/session-checkpoint.sh copilot || bash \"$HOME/.copilot/hooks/session-checkpoint.sh\" copilot'",
        "timeout": 15,
        "description": "Harness-managed safety hook"
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "sh -c '[ -f .github/hooks/pretool-guard.sh ] && bash .github/hooks/pretool-guard.sh copilot || bash \"$HOME/.copilot/hooks/pretool-guard.sh\" copilot'",
        "timeout": 5,
        "description": "Harness-managed safety hook"
      }
    ]
  }
}
