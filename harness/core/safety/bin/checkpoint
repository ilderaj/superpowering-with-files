#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: checkpoint <path> [--quiet] [--skip-if-clean] [--out=<dir>]
EOF
}

quiet=0
skip_if_clean=0
out_dir=""
source_path=""

for arg in "$@"; do
  case "$arg" in
    --quiet)
      quiet=1
      ;;
    --skip-if-clean)
      skip_if_clean=1
      ;;
    --out=*)
      out_dir="${arg#--out=}"
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      if [ -z "$source_path" ]; then
        source_path="$arg"
      else
        echo "Unexpected argument: $arg" >&2
        exit 1
      fi
      ;;
  esac
done

if [ -z "$source_path" ]; then
  source_path="."
fi

source_path="$(cd "$source_path" && pwd)"
timestamp="$(date -u +"%Y-%m-%dT%H-%M-%SZ")"
workspace_name="$(basename "$source_path")"

if [ -z "$out_dir" ]; then
  out_dir="$HOME/.agent-config/checkpoints/$workspace_name/$timestamp"
fi

case "$out_dir" in
  /*) ;;
  *)
    out_dir="$(cd . && pwd)/$out_dir"
    ;;
esac

tmp_dir="$(mktemp -d)"
cleanup() {
  rm -rf "$tmp_dir"
}
trap cleanup EXIT

json_escape() {
  node -e 'process.stdout.write(JSON.stringify(process.argv[1]))' "$1"
}

write_manifest() {
  local manifest_path="$1"
  local is_git_repo="$2"
  local branch="$3"
  local head_sha="$4"
  local remote="$5"
  cat >"$manifest_path" <<EOF
{
  "sourcePath": $(json_escape "$source_path"),
  "timestamp": $(json_escape "$timestamp"),
  "isGitRepo": $is_git_repo,
  "branch": $(json_escape "$branch"),
  "headSha": $(json_escape "$head_sha"),
  "remote": $(json_escape "$remote"),
  "checkpointPath": $(json_escape "$out_dir")
}
EOF
}

if git -C "$source_path" rev-parse --show-toplevel >/dev/null 2>&1; then
  git_root="$(git -C "$source_path" rev-parse --show-toplevel)"
  branch="$(git -C "$git_root" branch --show-current || true)"
  head_sha="$(git -C "$git_root" rev-parse HEAD)"
  remote="$(git -C "$git_root" remote get-url origin 2>/dev/null || true)"
  status_file="$tmp_dir/status.txt"
  untracked_list="$tmp_dir/untracked.list"
  git -C "$git_root" status --porcelain >"$status_file"
  git -C "$git_root" ls-files --others --exclude-standard -z >"$untracked_list"

  if [ "$skip_if_clean" -eq 1 ] && [ ! -s "$status_file" ]; then
    exit 0
  fi

  mkdir -p "$out_dir"
  git -C "$git_root" bundle create "$out_dir/repo.bundle" --all
  git -C "$git_root" diff >"$out_dir/uncommitted.diff"
  git -C "$git_root" diff --cached >"$out_dir/staged.diff"
  cp "$status_file" "$out_dir/status.txt"

  untracked_files=()
  while IFS= read -r -d '' file; do
    untracked_files+=("$file")
  done <"$untracked_list" || true
  if [ "${#untracked_files[@]}" -gt 0 ]; then
    tar -czf "$out_dir/untracked.tgz" -C "$git_root" "${untracked_files[@]}"
  else
    empty_dir="$tmp_dir/empty"
    mkdir -p "$empty_dir"
    tar -czf "$out_dir/untracked.tgz" -C "$empty_dir" .
  fi

  write_manifest "$out_dir/manifest.json" true "$branch" "$head_sha" "$remote"
else
  mkdir -p "$out_dir"
  tar \
    --exclude=node_modules \
    --exclude=.build \
    --exclude=DerivedData \
    --exclude=.next \
    --exclude=dist \
    --exclude=build \
    --exclude=.venv \
    -czf "$out_dir/workspace.tgz" \
    -C "$source_path" .
  write_manifest "$out_dir/manifest.json" false "" "" ""
fi

if [ "$quiet" -ne 1 ]; then
  echo "$out_dir"
fi
